generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      Int                       @id @default(autoincrement())
  email                   String                    @unique
  passwordHash            String                    @map("password_hash")
  name                    String
  role                    String                    @default("pca")
  phone                   String                    @default("") @map("phone")
  active                  Boolean                   @default(true) @map("active")
  archivedAt              DateTime?                 @map("archived_at")
  createdAt               DateTime                  @default(now()) @map("created_at")
  updatedAt               DateTime                  @updatedAt @map("updated_at")
  authorization_documents authorization_documents[]
  uploadedDocuments       ClientDocument[]
  activities              ClientActivity[]
  employee                Employee?
  assignedTasks           Task[]            @relation("TaskAssignee")
  triggerDefaults         WorkflowTrigger[] @relation("TriggerAssignee")
  sentScheduleNotifications ScheduleNotification[] @relation("ScheduleSentBy")

  @@map("users")
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  token     String    @unique @default(uuid())
  userId    Int       @map("user_id")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_reset_tokens")
}

model Employee {
  id                      Int                    @id @default(autoincrement())
  name                    String
  phone                   String                 @default("") @map("phone")
  email                   String                 @default("") @map("email")
  active                  Boolean                @default(true) @map("active")
  userId                  Int?                   @unique @map("user_id")
  archivedAt              DateTime?              @map("archived_at")
  createdAt               DateTime               @default(now()) @map("created_at")
  updatedAt               DateTime               @updatedAt @map("updated_at")
  dob                     DateTime?              @map("dob")
  address                 String                 @default("") @map("address")
  clientAssignment        String                 @default("") @map("client_assignment")
  npi                     String                 @default("") @map("npi")
  idExpDate               DateTime?              @map("id_exp_date")
  firstAssignmentDate     DateTime?              @map("first_assignment_date")
  tbDueDate               DateTime?              @map("tb_due_date")
  tbType                  String                 @default("") @map("tb_type")
  cprDueDate              DateTime?              @map("cpr_due_date")
  trainingDueDate         DateTime?              @map("training_due_date")
  backgroundCheckDueDate  DateTime?              @map("background_check_due_date")
  dischargeDate           DateTime?              @map("discharge_date")
  status                  String                 @default("active") @map("status")
  notes                   String                 @default("") @map("notes")
  critical                Boolean                @default(false) @map("critical")
  careTeamAssignments     ClientCareTeam[]
  certifications          EmployeeCertification[]
  scheduleLink            EmployeeScheduleLink?
  user                    User?                  @relation(fields: [userId], references: [id])
  notifications           ScheduleNotification[]
  shifts                  Shift[]
  payrollProfile          PayrollProfile?
  receipts                PayReceipt[]

  @@map("employees")
}

model EmployeeCertification {
  id           Int       @id @default(autoincrement())
  employeeId   Int       @map("employee_id")
  certType     String    @map("cert_type")
  expirationDate DateTime? @map("expiration_date")
  status       String    @default("active") @map("status")
  fileName     String    @default("") @map("file_name")
  fileSize     Int       @default(0) @map("file_size")
  fileType     String    @default("") @map("file_type")
  fileData     Bytes?    @map("file_data")
  notes        String    @default("") @map("notes")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, certType])
  @@map("employee_certifications")
}

model EmployeeScheduleLink {
  id         Int      @id @default(autoincrement())
  token      String   @unique @default(uuid())
  employeeId Int      @unique @map("employee_id")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_schedule_links")
}

model ScheduleNotification {
  id                Int       @id @default(autoincrement())
  employeeId        Int       @map("employee_id")
  weekStart         DateTime  @map("week_start")
  method            String    @map("method")
  destination       String    @map("destination")
  status            String    @default("pending") @map("status")
  confirmationToken String    @unique @default(uuid()) @map("confirmation_token")
  confirmedAt       DateTime? @map("confirmed_at")
  sentAt            DateTime? @map("sent_at")
  failureReason     String    @default("") @map("failure_reason")
  response          String    @default("") @map("response")
  responseNotes     String    @default("") @map("response_notes")
  respondedAt       DateTime? @map("responded_at")
  openedAt          DateTime? @map("opened_at")
  message           String    @default("") @map("message")
  sentById          Int?      @map("sent_by_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  sentByUser        User?     @relation("ScheduleSentBy", fields: [sentById], references: [id])

  @@index([employeeId])
  @@index([weekStart])
  @@map("schedule_notifications")
}

model Client {
  id                         Int              @id @default(autoincrement())
  clientName                 String           @map("client_name")
  medicaidId                 String           @default("") @map("medicaid_id")
  insuranceType              String           @default("MEDICAID") @map("insurance_type")
  address                    String           @default("") @map("address")
  phone                      String           @default("") @map("phone")
  gateCode                   String           @default("") @map("gate_code")
  notes                      String           @default("") @map("notes")
  enabledServices            String           @default("[\"PAS\",\"Homemaker\"]") @map("enabled_services")
  archivedAt                 DateTime?        @map("archived_at")
  createdAt                  DateTime         @default(now()) @map("created_at")
  updatedAt                  DateTime         @updatedAt @map("updated_at")
  backupDoctorName           String           @default("") @map("backup_doctor_name")
  backupDoctorPhone          String           @default("") @map("backup_doctor_phone")
  critical                   Boolean          @default(false) @map("critical")
  dob                        DateTime?        @map("dob")
  doctorName                 String           @default("") @map("doctor_name")
  doctorPhone                String           @default("") @map("doctor_phone")
  paNumber                   String           @default("") @map("pa_number")
  caregiverRequirements      String           @default("") @map("caregiver_requirements")
  email                      String           @default("") @map("email")
  emergencyContactName       String           @default("") @map("emergency_contact_name")
  emergencyContactPhone      String           @default("") @map("emergency_contact_phone")
  emergencyContactRelation   String           @default("") @map("emergency_contact_relation")
  gender                     String           @default("") @map("gender")
  mainServices               String           @default("") @map("main_services")
  pcaNotes                   String           @default("") @map("pca_notes")
  secondaryAddress           String           @default("") @map("secondary_address")
  secondaryEmergencyName     String           @default("") @map("secondary_emergency_name")
  secondaryEmergencyPhone    String           @default("") @map("secondary_emergency_phone")
  secondaryEmergencyRelation String           @default("") @map("secondary_emergency_relation")
  secondaryPhone             String           @default("") @map("secondary_phone")
  client_status              String           @default("active")
  authorizations             Authorization[]
  careTeam                   ClientCareTeam[]
  documents                  ClientDocument[]
  clientNotes                ClientNote[]
  hospitalVisits             HospitalVisit[]
  incidents                  Incident[]
  activities                 ClientActivity[]
  permanentLinks             PermanentLink[]
  shifts                     Shift[]
  timesheets                 Timesheet[]

  @@map("clients")
}

model ClientNote {
  id        Int      @id @default(autoincrement())
  clientId  Int      @map("client_id")
  date      DateTime
  type      String   @default("")
  content   String   @default("")
  createdAt DateTime @default(now()) @map("created_at")
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("client_notes")
}

model ClientCareTeam {
  id         Int      @id @default(autoincrement())
  clientId   Int      @map("client_id")
  employeeId Int      @map("employee_id")
  role       String   @default("agency_pca") @map("role")
  assignedAt DateTime @default(now()) @map("assigned_at")
  notes      String   @default("") @map("notes")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([employeeId])
  @@map("client_care_team")
}

model ClientDocument {
  id         Int      @id @default(autoincrement())
  clientId   Int      @map("client_id")
  category   String   @map("category")
  fileName   String   @map("file_name")
  filePath   String   @map("file_path")
  fileSize   Int      @map("file_size")
  mimeType   String   @default("") @map("mime_type")
  fileData   Bytes?   @map("file_data")
  uploadedBy Int?     @map("uploaded_by")
  notes      String   @default("") @map("notes")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uploader   User?    @relation(fields: [uploadedBy], references: [id])

  @@index([clientId])
  @@map("client_documents")
}

model HospitalVisit {
  id           Int      @id @default(autoincrement())
  clientId     Int      @map("client_id")
  visitDate    DateTime @map("visit_date")
  visitTime    String   @default("") @map("visit_time")
  providerName String   @default("") @map("provider_name")
  location     String   @default("") @map("location")
  purpose      String   @default("") @map("purpose")
  status       String   @default("upcoming") @map("status")
  notes        String   @default("") @map("notes")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("hospital_visits")
}

model Incident {
  id           Int       @id @default(autoincrement())
  clientId     Int       @map("client_id")
  incidentDate DateTime  @map("incident_date")
  description  String    @default("") @map("description")
  severity     String    @default("minor") @map("severity")
  reportedBy   String    @default("") @map("reported_by")
  status       String    @default("open") @map("status")
  resolvedAt   DateTime? @map("resolved_at")
  resolution   String    @default("") @map("resolution")
  notes        String    @default("") @map("notes")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  client       Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("incidents")
}

model ClientActivity {
  id          Int      @id @default(autoincrement())
  clientId    Int      @map("client_id")
  userId      Int      @map("user_id")
  type        String   @map("type")
  subject     String   @default("")
  description String   @default("")
  contactName String   @default("") @map("contact_name")
  occurredAt  DateTime @map("occurred_at")
  createdAt   DateTime @default(now()) @map("created_at")
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])

  @@index([clientId])
  @@map("client_activities")
}

model Authorization {
  id                      Int                       @id @default(autoincrement())
  clientId                Int                       @map("client_id")
  serviceCategory         String                    @default("") @map("service_category")
  serviceCode             String                    @map("service_code")
  serviceName             String                    @default("") @map("service_name")
  authorizedUnits         Int                       @default(0) @map("authorized_units")
  authorizationStartDate  DateTime?                 @map("authorization_start_date")
  authorizationEndDate    DateTime?                 @map("authorization_end_date")
  notes                   String                    @default("") @map("notes")
  createdAt               DateTime                  @default(now()) @map("created_at")
  updatedAt               DateTime                  @updatedAt @map("updated_at")
  archivedAt              DateTime?                 @map("archived_at")
  authorizationNumber     String                    @default("") @map("authorization_number")
  authorizedHours         Float                     @default(0) @map("authorized_hours")
  accountNumber           String                    @default("") @map("account_number")
  sandataClientId         String                    @default("") @map("sandata_client_id")
  manualStatus            String                    @default("active") @map("manual_status")
  authorization_documents authorization_documents[]
  client                  Client                    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("authorizations")
}

model InsuranceType {
  id         Int       @id @default(autoincrement())
  name       String    @unique
  color      String    @default("#9E9E9E")
  archivedAt DateTime? @map("archived_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("insurance_types")
}

model Service {
  id         Int       @id @default(autoincrement())
  category   String
  code       String    @unique
  name       String    @default("")
  archivedAt DateTime? @map("archived_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("services")
}

model Timesheet {
  id                  Int              @id @default(autoincrement())
  clientId            Int              @map("client_id")
  clientPhone         String           @default("") @map("client_phone")
  clientIdNumber      String           @default("") @map("client_id_number")
  pcaName             String           @map("pca_name")
  weekStart           DateTime         @map("week_start")
  status              String           @default("draft")
  totalPasHours       Float            @default(0) @map("total_pas_hours")
  totalHmHours        Float            @default(0) @map("total_hm_hours")
  totalHours          Float            @default(0) @map("total_hours")
  totalRespiteHours   Float            @default(0) @map("total_respite_hours")
  totalCompanionHours Float            @default(0) @map("total_companion_hours")
  recipientName       String           @default("") @map("recipient_name")
  recipientSignature  String           @default("") @map("recipient_signature")
  pcaSignature        String           @default("") @map("pca_signature")
  pcaFullName         String           @default("") @map("pca_full_name")
  supervisorName      String           @default("Sona Hakobyan") @map("supervisor_name")
  supervisorSignature String           @default("") @map("supervisor_signature")
  completionDate      String           @default("") @map("completion_date")
  correctionNote      String           @default("") @map("correction_note")
  submittedAt         DateTime?        @map("submitted_at")
  acceptedAt          DateTime?        @map("accepted_at")
  archivedAt          DateTime?        @map("archived_at")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  signingTokens       SigningToken[]
  entries             TimesheetEntry[]
  reminders           TimesheetReminder[]
  client              Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, pcaName, weekStart])
  @@map("timesheets")
}

model TimesheetEntry {
  id                    Int       @id @default(autoincrement())
  timesheetId           Int       @map("timesheet_id")
  dayOfWeek             Int       @map("day_of_week")
  dateOfService         String    @default("") @map("date_of_service")
  adlActivities         String    @default("{}") @map("adl_activities")
  adlTimeIn             String?   @map("adl_time_in")
  adlTimeOut            String?   @map("adl_time_out")
  adlHours              Float     @default(0) @map("adl_hours")
  adlPcaInitials        String    @default("") @map("adl_pca_initials")
  adlClientInitials     String    @default("") @map("adl_client_initials")
  adlTimeBlocks         String    @default("[]") @map("adl_time_blocks")
  iadlActivities        String    @default("{}") @map("iadl_activities")
  iadlTimeIn            String?   @map("iadl_time_in")
  iadlTimeOut           String?   @map("iadl_time_out")
  iadlHours             Float     @default(0) @map("iadl_hours")
  iadlPcaInitials       String    @default("") @map("iadl_pca_initials")
  iadlClientInitials    String    @default("") @map("iadl_client_initials")
  iadlTimeBlocks        String    @default("[]") @map("iadl_time_blocks")
  respiteActivities     String    @default("{}") @map("respite_activities")
  respiteTimeIn         String?   @map("respite_time_in")
  respiteTimeOut        String?   @map("respite_time_out")
  respiteHours          Float     @default(0) @map("respite_hours")
  respitePcaInitials    String    @default("") @map("respite_pca_initials")
  respiteClientInitials String    @default("") @map("respite_client_initials")
  respiteTimeBlocks     String    @default("[]") @map("respite_time_blocks")
  companionActivities   String    @default("{}") @map("companion_activities")
  companionTimeIn       String?   @map("companion_time_in")
  companionTimeOut      String?   @map("companion_time_out")
  companionHours        Float     @default(0) @map("companion_hours")
  companionPcaInitials  String    @default("") @map("companion_pca_initials")
  companionClientInitials String  @default("") @map("companion_client_initials")
  companionTimeBlocks   String    @default("[]") @map("companion_time_blocks")
  timesheet             Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)

  @@map("timesheet_entries")
}

model SigningToken {
  id          Int       @id @default(autoincrement())
  token       String    @unique
  timesheetId Int       @map("timesheet_id")
  role        String
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  timesheet   Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)

  @@map("signing_tokens")
}

model PayrollRun {
  id                    Int            @id @default(autoincrement())
  name                  String
  fileName              String         @map("file_name")
  periodStart           DateTime?      @map("period_start")
  periodEnd             DateTime?      @map("period_end")
  status                String         @default("processing")
  totalVisits           Int            @default(0) @map("total_visits")
  totalPayable          Int            @default(0) @map("total_payable")
  errorMessage          String?        @map("error_message")
  authorizationSnapshot String         @default("{}") @map("authorization_snapshot")
  archivedAt            DateTime?      @map("archived_at")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")
  visits                PayrollVisit[]

  @@map("payroll_runs")
}

model PayrollVisit {
  id                Int        @id @default(autoincrement())
  runId             Int        @map("run_id")
  clientName        String     @default("") @map("client_name")
  employeeName      String     @default("") @map("employee_name")
  service           String     @default("")
  visitDate         DateTime?  @map("visit_date")
  callInRaw         Float      @default(0) @map("call_in_raw")
  callOutRaw        Float      @default(0) @map("call_out_raw")
  callHoursRaw      Float      @default(0) @map("call_hours_raw")
  visitStatus       String     @default("") @map("visit_status")
  unitsRaw          Int        @default(0) @map("units_raw")
  serviceCode       String     @default("") @map("service_code")
  callInTime        String     @default("") @map("call_in_time")
  callOutTime       String     @default("") @map("call_out_time")
  durationMinutes   Int        @default(0) @map("duration_minutes")
  finalPayableUnits Int        @default(0) @map("final_payable_units")
  voidFlag          Boolean    @default(false) @map("void_flag")
  voidReason        String     @default("") @map("void_reason")
  overlapId         String     @default("") @map("overlap_id")
  isIncomplete      Boolean    @default(false) @map("is_incomplete")
  isUnauthorized    Boolean    @default(false) @map("is_unauthorized")
  needsReview       Boolean    @default(false) @map("needs_review")
  reviewReason      String     @default("") @map("review_reason")
  notes             String     @default("") @map("notes")
  mergedInto        Int?       @map("merged_into")
  earlyCallIn       Boolean    @default(false) @map("early_call_in")
  lateCallOut       Boolean    @default(false) @map("late_call_out")
  nextDayCallOut    Boolean    @default(false) @map("next_day_call_out")
  createdAt         DateTime   @default(now()) @map("created_at")
  run               PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("payroll_visits")
}

model PayrollProfile {
  id                     Int       @id @default(autoincrement())
  employeeId             Int       @unique @map("employee_id")
  hourlyRate             Decimal   @default(0) @map("hourly_rate") @db.Decimal(10, 2)
  classification         String    @default("W2") @map("classification")
  ein                    String    @default("") @map("ein")
  ssn                    String    @default("") @map("ssn")
  accountNumber          String    @default("") @map("account_number")
  garnishmentActive      Boolean   @default(false) @map("garnishment_active")
  childSupportActive     Boolean   @default(false) @map("child_support_active")
  childSupportAmount     Decimal   @default(0) @map("child_support_amount") @db.Decimal(10, 2)
  overpaymentBalance     Decimal   @default(0) @map("overpayment_balance") @db.Decimal(10, 2)
  ytdGrossOverride       Decimal?  @map("ytd_gross_override") @db.Decimal(10, 2)
  ytdDeductionsOverride  Decimal?  @map("ytd_deductions_override") @db.Decimal(10, 2)
  ytdNetOverride         Decimal?  @map("ytd_net_override") @db.Decimal(10, 2)
  ytdOverpaymentOverride Decimal?  @map("ytd_overpayment_override") @db.Decimal(10, 2)
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  employee               Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("payroll_profiles")
}

model PayReceipt {
  id                   Int       @id @default(autoincrement())
  employeeId           Int       @map("employee_id")
  periodStart          DateTime  @map("period_start")
  periodEnd            DateTime  @map("period_end")
  payDate              DateTime  @map("pay_date")
  totalHours           Decimal   @default(0) @map("total_hours") @db.Decimal(10, 2)
  hourlyRate           Decimal   @default(0) @map("hourly_rate") @db.Decimal(10, 2)
  grossEarnings        Decimal   @default(0) @map("gross_earnings") @db.Decimal(10, 2)
  garnishment          Decimal   @default(0) @map("garnishment") @db.Decimal(10, 2)
  childSupport         Decimal   @default(0) @map("child_support") @db.Decimal(10, 2)
  overpaymentDeduction Decimal   @default(0) @map("overpayment_deduction") @db.Decimal(10, 2)
  otherDeductions      Decimal   @default(0) @map("other_deductions") @db.Decimal(10, 2)
  netPay               Decimal   @default(0) @map("net_pay") @db.Decimal(10, 2)
  ytdGross             Decimal   @default(0) @map("ytd_gross") @db.Decimal(10, 2)
  ytdDeductions        Decimal   @default(0) @map("ytd_deductions") @db.Decimal(10, 2)
  ytdOverpayments      Decimal   @default(0) @map("ytd_overpayments") @db.Decimal(10, 2)
  ytdNet               Decimal   @default(0) @map("ytd_net") @db.Decimal(10, 2)
  classification       String    @default("W2") @map("classification")
  status               String    @default("draft") @map("status")
  emailSentAt          DateTime? @map("email_sent_at")
  notes                String    @default("") @map("notes")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  employee             Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, periodStart])
  @@index([employeeId])
  @@index([periodStart])
  @@map("pay_receipts")
}

model Shift {
  id               Int       @id @default(autoincrement())
  clientId         Int       @map("client_id")
  employeeId       Int?      @map("employee_id")
  serviceCode      String    @map("service_code")
  shiftDate        DateTime  @map("shift_date")
  startTime        String    @map("start_time")
  endTime          String    @map("end_time")
  hours            Float     @default(0)
  units            Int       @default(0)
  notes            String    @default("")
  status           String    @default("scheduled")
  recurringGroupId String    @default("") @map("recurring_group_id")
  accountNumber    String    @default("") @map("account_number")
  sandataClientId  String    @default("") @map("sandata_client_id")
  archivedAt       DateTime? @map("archived_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  client           Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  employee         Employee? @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@index([clientId])
  @@index([employeeId])
  @@index([shiftDate])
  @@map("shifts")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  userName   String   @map("user_name")
  userRole   String   @map("user_role")
  action     String
  entityType String   @map("entity_type")
  entityId   Int      @map("entity_id")
  entityName String   @default("") @map("entity_name")
  changes    String   @default("[]")
  metadata   String   @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([entityType, createdAt])
  @@index([userId])
  @@map("audit_logs")
}

model PermanentLink {
  id        Int      @id @default(autoincrement())
  token     String   @unique @default(uuid())
  clientId  Int      @map("client_id")
  pcaName   String   @map("pca_name")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, pcaName])
  @@map("permanent_links")
}

model authorization_documents {
  id               Int           @id @default(autoincrement())
  authorization_id Int
  file_name        String
  file_path        String
  file_size        Int
  mime_type        String        @default("")
  file_data        Bytes?
  uploaded_by      Int?
  notes            String        @default("")
  created_at       DateTime      @default(now())
  authorizations   Authorization @relation(fields: [authorization_id], references: [id], onDelete: Cascade)
  users            User?         @relation(fields: [uploaded_by], references: [id])

  @@index([authorization_id])
}

model BulkEditBatch {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  userName   String    @map("user_name")
  action     String    @default("UPDATE")
  shiftCount Int       @map("shift_count")
  snapshot   String    @default("[]")
  undoneAt   DateTime? @map("undone_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("bulk_edit_batches")
}

model TimesheetReminder {
  id          Int       @id @default(autoincrement())
  timesheetId Int       @map("timesheet_id")
  employeeId  Int?      @map("employee_id")
  sentAt      DateTime  @default(now()) @map("sent_at")
  channel     String    @default("email")
  status      String    @default("sent")

  timesheet   Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)

  @@map("timesheet_reminders")
}

model Task {
  id               Int       @id @default(autoincrement())
  title            String
  description      String    @default("") @map("description")
  notes            String    @default("") @map("notes")
  status           String    @default("open") @map("status")
  urgency          String    @default("medium") @map("urgency")
  dueDate          DateTime? @map("due_date")
  assignedToUserId Int?      @map("assigned_to_user_id")
  assignedToRole   String?   @map("assigned_to_role")
  entityType       String?   @map("entity_type")
  entityId         Int?      @map("entity_id")
  triggerId        Int?      @map("trigger_id")
  completedAt      DateTime? @map("completed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  assignedToUser User?            @relation("TaskAssignee", fields: [assignedToUserId], references: [id])
  trigger        WorkflowTrigger? @relation(fields: [triggerId], references: [id])
  reminders      TaskReminder[]

  @@index([status])
  @@index([assignedToUserId])
  @@index([triggerId, entityType, entityId])
  @@map("tasks")
}

model WorkflowTrigger {
  id             Int      @id @default(autoincrement())
  name           String
  type           String
  enabled        Boolean  @default(true)
  thresholdDays  Int      @map("threshold_days")
  urgency        String   @default("medium")
  assignToRole   String?  @map("assign_to_role")
  assignToUserId Int?     @map("assign_to_user_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tasks        Task[]
  assignToUser User? @relation("TriggerAssignee", fields: [assignToUserId], references: [id])

  @@map("workflow_triggers")
}

model TaskReminder {
  id      Int      @id @default(autoincrement())
  taskId  Int      @map("task_id")
  sentAt  DateTime @default(now()) @map("sent_at")
  channel String
  status  String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_reminders")
}
